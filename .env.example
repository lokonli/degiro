# Copy to .env.local (gitignored) and fill in. Used by lib/degiroClient.ts to log in and
# pull transactions directly from DEGIRO's API — see /import in the app and DEPLOYMENT.md.
DEGIRO_USERNAME=
DEGIRO_PASSWORD=
# Base32 TOTP secret for the account's 2FA (not a 6-digit code — the long-lived seed).
DEGIRO_TOTP_SECRET=
